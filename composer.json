{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-dom": "*",
        "devdojo/auth": "^1.1.1",
        "filament/filament": "^3.3.50",
        "inertiajs/inertia-laravel": "^1.3.4",
        "laravel/breeze": "^2.4.1",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3.1",
        "laravel/socialite": "^5.26.1",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^2.11.1",
        "livewire/livewire": "^3.7.15",
        "pusher/pusher-php-server": "^7.2.7",
        "socialiteproviders/google": "^4.1",
        "spatie/laravel-sluggable": "^3.8.1",
        "tightenco/ziggy": "^2.6.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "laravel/pint": "^1.29.0",
        "laravel/sail": "^1.56",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "spatie/laravel-ignition": "^2.12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
